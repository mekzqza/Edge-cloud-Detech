# เทมเพลต — คัดลอกเป็น .env แล้วใส่ค่าจริง:  cp .env.example .env
POSTGRES_USER=myuser
POSTGRES_PASSWORD=change-me
POSTGRES_DB=appdb

# คีย์เซ็น token/session (backend + NextAuth ใช้ตัวเดียวกัน) — สุ่มด้วย: openssl rand -base64 32
AUTH_SECRET=change-me

# admin คนแรก seed ตอน db เริ่ม
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
